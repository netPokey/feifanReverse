.center-hero,.debug-panel,.glass-hero,.hero,.profile-panel {
    background: linear-gradient(145deg,rgba(19,27,42,.94),rgba(10,15,26,.98) 64%,rgba(8,12,21,.99));
    border: 1rpx solid rgba(148,163,184,.12);
    border-radius: 34rpx;
    box-shadow: 0 28rpx 76rpx rgba(0,0,0,.46),inset 0 1rpx 0 hsla(0,0%,100%,.055);
    color: #fff;
    overflow: hidden;
    position: relative
}

.center-hero::after,.debug-panel::after,.glass-hero::after,.hero::after,.profile-panel::after {
    -webkit-animation: none;
    animation: none;
    background: linear-gradient(90deg,rgba(148,163,184,0),rgba(148,163,184,.055),rgba(125,211,252,.035),rgba(148,163,184,0));
    content: "";
    height: 180rpx;
    left: -20%;
    opacity: .42;
    pointer-events: none;
    position: absolute;
    right: -20%;
    top: -80rpx;
    z-index: 0
}

.center-hero > wx-view,.debug-panel > wx-view,.glass-hero > wx-view,.hero > wx-view,.profile-panel > wx-view {
    position: relative;
    z-index: 1
}

