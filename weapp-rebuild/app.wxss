@font-face {
    font-family: Orbitron;
    font-style: normal;
    font-weight: 900;
    src: url(data:font/truetype;charset=utf-8;base64,) format("truetype")
}

page {
    background: #080d18;
    color: #f8fafc;
    font-family: -apple-system,BlinkMacSystemFont,Helvetica Neue,Helvetica,Arial,sans-serif;
    font-size: 28rpx
}

.page,page {
    min-height: 100vh
}

.page {
    -webkit-animation: pageSoftEnter .18s ease-out both;
    animation: pageSoftEnter .18s ease-out both;
    background: radial-gradient(circle at 50% -16%,rgba(74,222,255,.07) 0,rgba(74,222,255,.018) 360rpx,rgba(74,222,255,0) 620rpx),radial-gradient(circle at 92% 88%,rgba(99,102,241,.028) 0,rgba(99,102,241,0) 460rpx),linear-gradient(180deg,#0b1220,#080d18 600rpx,#070b13),#070b13;
    box-sizing: border-box;
    overflow-x: hidden;
    padding: var(--page-shell-top,calc(22rpx + env(safe-area-inset-top))) 24rpx 190rpx;
    position: relative;
    transition: background-color .18s ease,color .18s ease
}

.font-default,.font-small,.page {
    --app-font-scale: 1
}

.font-large {
    --app-font-scale: 1.22
}

.section {
    margin-bottom: 24rpx;
    position: relative
}

.card,.glass,.panel {
    background: linear-gradient(145deg,rgba(22,30,46,.96),rgba(13,18,30,.99) 56%,#080c15);
    border: 1rpx solid rgba(148,163,184,.14);
    border-radius: 34rpx;
    box-shadow: 0 24rpx 68rpx rgba(0,0,0,.5),inset 0 1rpx 0 hsla(0,0%,100%,.055);
    box-sizing: border-box
}

.panel {
    padding: 26rpx
}

.row {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    gap: 22rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    min-height: 78rpx
}

.row > wx-view:first-child {
    -webkit-flex: 1;
    flex: 1;
    min-width: 0
}

.muted {
    color: #8fa0b4;
    font-size: calc(24rpx * var(--app-font-scale));
    line-height: 1.45
}

.strong {
    color: #f8fafc;
    font-size: calc(28rpx * var(--app-font-scale));
    font-weight: 800;
    line-height: 1.25
}

.tag {
    -webkit-align-items: center;
    align-items: center;
    background: rgba(30,41,59,.72);
    border: 1rpx solid rgba(125,211,252,.22);
    border-radius: 21rpx;
    box-shadow: inset 0 1rpx 0 hsla(0,0%,100%,.06);
    box-sizing: border-box;
    color: #b9d7e8;
    display: -webkit-flex;
    display: flex;
    font-size: calc(22rpx * var(--app-font-scale));
    font-weight: 600;
    -webkit-justify-content: center;
    justify-content: center;
    line-height: 1;
    min-height: 42rpx;
    min-width: 84rpx;
    padding: 0 16rpx;
    white-space: nowrap
}

.button-row {
    -webkit-flex-wrap: wrap;
    flex-wrap: wrap;
    gap: 16rpx
}

.btn,.button-row {
    display: -webkit-flex;
    display: flex;
    position: relative
}

.btn {
    -webkit-align-items: center;
    align-items: center;
    background: linear-gradient(135deg,#74d8ff,#43e6c5);
    border-radius: 22rpx;
    box-shadow: 0 18rpx 42rpx rgba(0,0,0,.26),inset 0 1rpx 0 hsla(0,0%,100%,.34);
    box-sizing: border-box;
    color: #031014;
    font-size: calc(27rpx * var(--app-font-scale));
    font-weight: 600;
    gap: 10rpx;
    height: 72rpx;
    -webkit-justify-content: center;
    justify-content: center;
    line-height: 1;
    min-width: 128rpx;
    overflow: hidden;
    padding: 0 24rpx;
    transition: opacity .18s ease,box-shadow .24s ease,border-color .24s ease,-webkit-transform .18s cubic-bezier(.2,.9,.22,1.18);
    transition: transform .18s cubic-bezier(.2,.9,.22,1.18),opacity .18s ease,box-shadow .24s ease,border-color .24s ease;
    transition: transform .18s cubic-bezier(.2,.9,.22,1.18),opacity .18s ease,box-shadow .24s ease,border-color .24s ease,-webkit-transform .18s cubic-bezier(.2,.9,.22,1.18);
    white-space: nowrap
}

.btn::after {
    display: none
}

.btn-icon {
    display: block;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    height: 30rpx;
    width: 30rpx
}

.btn:active {
    opacity: .82;
    -webkit-transform: scale(.965);
    transform: scale(.965)
}

.btn.secondary {
    background: rgba(22,30,46,.88);
    border: 1rpx solid rgba(125,211,252,.18);
    box-shadow: inset 0 1rpx 0 hsla(0,0%,100%,.055);
    color: #b9e6f7
}

.btn.warn {
    background: linear-gradient(135deg,#8be8df,#67d49a);
    box-shadow: 0 14rpx 30rpx rgba(0,0,0,.22),inset 0 1rpx 0 hsla(0,0%,100%,.28);
    color: #031014
}

.btn.disabled,.btn.is-disabled {
    background: rgba(148,163,184,.14);
    border: 1rpx solid rgba(148,163,184,.18);
    box-shadow: none;
    color: #8fa0b5
}

.grid {
    display: grid;
    gap: 16rpx;
    grid-template-columns: repeat(2,minmax(0,1fr));
    position: relative
}

.card {
    min-height: 126rpx;
    padding: 22rpx;
    transition: border-color .22s ease,box-shadow .22s ease,-webkit-transform .18s cubic-bezier(.2,.9,.22,1.18);
    transition: transform .18s cubic-bezier(.2,.9,.22,1.18),border-color .22s ease,box-shadow .22s ease;
    transition: transform .18s cubic-bezier(.2,.9,.22,1.18),border-color .22s ease,box-shadow .22s ease,-webkit-transform .18s cubic-bezier(.2,.9,.22,1.18)
}

.card:active {
    -webkit-transform: scale(.985);
    transform: scale(.985)
}

.card-title {
    color: #8fa0b4;
    font-size: calc(23rpx * var(--app-font-scale));
    line-height: 1.25
}

.card-value {
    color: #f8fafc;
    font-size: calc(34rpx * var(--app-font-scale));
    font-weight: 700;
    line-height: 1.14;
    margin-top: 10rpx;
    word-break: break-all
}

.empty {
    -webkit-align-items: center;
    align-items: center;
    color: #a4b1c3;
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: center;
    justify-content: center;
    line-height: 1.5;
    min-height: 188rpx;
    text-align: center
}

wx-input,wx-textarea {
    background: rgba(15,23,42,.82);
    border: 1rpx solid rgba(148,163,184,.16);
    border-radius: 20rpx;
    box-shadow: inset 0 1rpx 0 hsla(0,0%,100%,.055);
    box-sizing: border-box;
    color: #f8fafc
}

wx-input {
    height: 76rpx;
    padding: 0 22rpx
}

wx-textarea {
    padding: 20rpx 22rpx;
    width: 100%
}

wx-slider {
    margin: 10rpx 0 22rpx
}

.neo-switch {
    -webkit-align-items: center;
    align-items: center;
    background: hsla(0,0%,100%,.07);
    border: 1rpx solid hsla(0,0%,100%,.14);
    border-radius: 999rpx;
    box-shadow: inset 0 2rpx 8rpx rgba(0,0,0,.22);
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    height: 48rpx;
    padding: 6rpx;
    transition: all .26s cubic-bezier(.2,.9,.22,1.18);
    width: 88rpx
}

.neo-switch:active {
    -webkit-transform: scale(.95);
    transform: scale(.95)
}

.neo-switch.is-on {
    background: linear-gradient(90deg,rgba(20,184,166,.34),rgba(56,189,248,.18));
    border-color: rgba(94,234,212,.26);
    box-shadow: inset 0 1rpx 0 hsla(0,0%,100%,.1)
}

.neo-switch.is-disabled {
    opacity: .44
}

.neo-switch__thumb {
    background: #667085;
    border-radius: 50%;
    box-shadow: 0 6rpx 14rpx rgba(0,0,0,.34);
    height: 34rpx;
    transition: all .26s cubic-bezier(.18,.9,.22,1.24);
    width: 34rpx
}

.neo-switch.is-on .neo-switch__thumb {
    background: #8be8df;
    box-shadow: 0 4rpx 14rpx rgba(0,0,0,.22);
    -webkit-transform: translateX(38rpx) scale(1.12,.92);
    transform: translateX(38rpx) scale(1.12,.92)
}

.neo-switch--sm {
    height: 42rpx;
    padding: 5rpx;
    width: 78rpx
}

.neo-switch--sm .neo-switch__thumb {
    height: 30rpx;
    width: 30rpx
}

.neo-switch--sm.is-on .neo-switch__thumb {
    -webkit-transform: translateX(34rpx) scale(1.06);
    transform: translateX(34rpx) scale(1.06)
}

.page-shell {
    -webkit-animation: pageSoftEnter .18s ease-out both;
    animation: pageSoftEnter .18s ease-out both;
    box-sizing: border-box;
    min-height: 100vh;
    padding-bottom: 190rpx
}

@-webkit-keyframes pageSoftEnter {
    from {
        opacity: .72;
        -webkit-transform: translateY(8rpx);
        transform: translateY(8rpx)
    }

    to {
        opacity: 1;
        -webkit-transform: translateY(0);
        transform: translateY(0)
    }
}

@keyframes pageSoftEnter {
    from {
        opacity: .72;
        -webkit-transform: translateY(8rpx);
        transform: translateY(8rpx)
    }

    to {
        opacity: 1;
        -webkit-transform: translateY(0);
        transform: translateY(0)
    }
}

.page-titlebar {
    -webkit-align-items: flex-start;
    align-items: flex-start;
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    -webkit-justify-content: center;
    justify-content: center;
    margin: 0 0 30rpx;
    min-height: 76rpx;
    padding-right: 190rpx;
    position: relative
}

.page-titlebar--with-back {
    box-sizing: border-box;
    min-height: 88rpx;
    padding-left: 74rpx;
    position: relative
}

.page-titlebar__back {
    -webkit-align-items: center;
    align-items: center;
    background: hsla(0,0%,100%,.08);
    border: 1rpx solid hsla(0,0%,100%,.16);
    border-radius: 20rpx;
    box-shadow: 0 12rpx 32rpx rgba(0,0,0,.32),inset 0 1rpx 0 hsla(0,0%,100%,.1);
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    height: 56rpx;
    -webkit-justify-content: center;
    justify-content: center;
    left: 0;
    position: absolute;
    top: 50%;
    -webkit-transform: translateY(-50%);
    transform: translateY(-50%);
    transition: opacity .18s ease,border-color .2s ease,-webkit-transform .18s cubic-bezier(.2,.9,.22,1.18);
    transition: transform .18s cubic-bezier(.2,.9,.22,1.18),opacity .18s ease,border-color .2s ease;
    transition: transform .18s cubic-bezier(.2,.9,.22,1.18),opacity .18s ease,border-color .2s ease,-webkit-transform .18s cubic-bezier(.2,.9,.22,1.18);
    width: 56rpx
}

.page-titlebar__back:active {
    opacity: .72;
    -webkit-transform: translateY(-50%) scale(.94);
    transform: translateY(-50%) scale(.94)
}

.page-titlebar__back-icon {
    display: block;
    height: 28rpx;
    width: 28rpx
}

.page-titlebar__eyebrow {
