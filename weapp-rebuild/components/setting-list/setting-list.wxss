.setting-list {
    background: linear-gradient(145deg,rgba(20,28,44,.96),#0a0e16);
    border: 1rpx solid rgba(148,163,184,.14);
    border-radius: 28rpx;
    box-shadow: 0 22rpx 58rpx rgba(0,0,0,.46),inset 0 1rpx 0 hsla(0,0%,100%,.06);
    overflow: hidden
}

.setting-list__row {
    -webkit-align-items: center;
    align-items: center;
    border-bottom: 1rpx solid rgba(148,163,184,.12);
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    gap: 22rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    min-height: 104rpx;
    padding: 20rpx 24rpx;
    transition: background .22s ease,opacity .18s ease,-webkit-transform .18s cubic-bezier(.2,.9,.22,1.18);
    transition: background .22s ease,transform .18s cubic-bezier(.2,.9,.22,1.18),opacity .18s ease;
    transition: background .22s ease,transform .18s cubic-bezier(.2,.9,.22,1.18),opacity .18s ease,-webkit-transform .18s cubic-bezier(.2,.9,.22,1.18)
}

.setting-list__row:active {
    background: rgba(148,163,184,.055);
    -webkit-transform: scale(.992);
    transform: scale(.992)
}

.setting-list__row.is-disabled {
    opacity: .68
}

.setting-list__row:last-child {
    border-bottom: 0
}

.setting-list__main {
    -webkit-flex: 1;
    flex: 1;
    gap: 18rpx;
    min-width: 0
}

.setting-list__icon,.setting-list__main {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex
}

.setting-list__icon {
    background: linear-gradient(145deg,rgba(30,41,59,.94),rgba(15,23,42,.98));
    border: 1rpx solid rgba(148,163,184,.16);
    border-radius: 20rpx;
    box-shadow: inset 0 1rpx 0 hsla(0,0%,100%,.08);
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    height: 64rpx;
    -webkit-justify-content: center;
    justify-content: center;
    width: 64rpx
}

.setting-list__icon-text {
    color: #b9d7e8;
    font-size: calc(26rpx * var(--app-font-scale));
    font-weight: 900;
    line-height: 1
}

.setting-list__icon-image {
    display: block;
    height: 34rpx;
    width: 34rpx
}

.setting-list__copy {
    -webkit-flex: 1;
    flex: 1;
    min-width: 0
}

.setting-list__name {
    color: rgba(248,250,252,.98);
    font-size: calc(29rpx * var(--app-font-scale));
    font-weight: 800;
    line-height: 1.24
}

.setting-list__desc {
    color: #8fa0b4;
    line-height: 1.42;
    margin-top: 8rpx
}

.setting-list__desc,.setting-list__value {
    font-size: calc(23rpx * var(--app-font-scale))
}

.setting-list__value {
    color: #b9e6f7;
    font-weight: 700;
    line-height: 1.25;
    margin-top: 10rpx;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    text-shadow: none;
    white-space: nowrap;
    word-break: keep-all
}

.setting-list__switch-control {
    -webkit-justify-content: flex-end;
    justify-content: flex-end;
    min-width: 82rpx
}

.neo-switch,.setting-list__switch-control {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-shrink: 0;
    flex-shrink: 0
}

.neo-switch {
    background: hsla(0,0%,100%,.07);
    border: 1rpx solid hsla(0,0%,100%,.13);
    border-radius: 999rpx;
    box-shadow: inset 0 2rpx 8rpx rgba(0,0,0,.22);
    box-sizing: border-box;
    height: 48rpx;
    padding: 6rpx;
    transition: all .26s cubic-bezier(.2,.9,.22,1.18);
    width: 88rpx
}

.neo-switch:active {
    -webkit-transform: scale(.95);
    transform: scale(.95)
}

.neo-switch.is-on {
    background: linear-gradient(90deg,rgba(20,184,166,.34),rgba(56,189,248,.18));
    border-color: rgba(94,234,212,.26);
    box-shadow: inset 0 1rpx 0 hsla(0,0%,100%,.1)
}

.neo-switch.is-disabled {
    opacity: .44
}

.neo-switch__thumb {
    background: #667085;
    border-radius: 50%;
    box-shadow: 0 6rpx 14rpx rgba(0,0,0,.34);
    height: 34rpx;
    transition: all .26s cubic-bezier(.18,.9,.22,1.24);
    width: 34rpx
}

.neo-switch.is-on .neo-switch__thumb {
    background: #8be8df;
    box-shadow: 0 4rpx 14rpx rgba(0,0,0,.22);
    -webkit-transform: translateX(38rpx) scale(1.12,.92);
    transform: translateX(38rpx) scale(1.12,.92)
}

.neo-switch--sm {
    height: 42rpx;
    padding: 5rpx;
    width: 78rpx
}

.neo-switch--sm .neo-switch__thumb {
    height: 30rpx;
    width: 30rpx
}

.neo-switch--sm.is-on .neo-switch__thumb {
    -webkit-transform: translateX(34rpx) scale(1.06);
    transform: translateX(34rpx) scale(1.06)
}

.setting-list__select {
    -webkit-align-items: center;
    align-items: center;
    background: rgba(30,41,59,.7);
    border: 1rpx solid rgba(125,211,252,.2);
    border-radius: 18rpx;
    box-shadow: inset 0 1rpx 0 hsla(0,0%,100%,.045);
    box-sizing: border-box;
    color: #b9e6f7;
    display: -webkit-flex;
    display: flex;
    font-size: calc(22rpx * var(--app-font-scale));
    font-weight: 800;
    height: 52rpx;
    -webkit-justify-content: center;
    justify-content: center;
    min-width: 92rpx;
    padding: 0 18rpx;
    white-space: nowrap
}

.setting-list__select.is-disabled {
    background: rgba(148,163,184,.14);
    border-color: rgba(148,163,184,.18);
    color: #8fa0b5
}

.setting-list--day {
    background: linear-gradient(145deg,hsla(0,0%,100%,.96),rgba(241,247,252,.9));
    border-color: rgba(8,145,178,.13);
    box-shadow: 0 18rpx 42rpx rgba(15,23,42,.08),inset 0 1rpx 0 hsla(0,0%,100%,.72)
}

.setting-list--day .setting-list__row {
    border-bottom-color: rgba(15,23,42,.07)
}

.setting-list--day .setting-list__icon {
    background: rgba(8,145,178,.07);
    border-color: rgba(8,145,178,.14)
}

.setting-list--day .setting-list__name {
    color: #0f172a
}

.setting-list--day .setting-list__desc {
    color: #64748b
}

.setting-list--day .setting-list__select,.setting-list--day .setting-list__value {
    color: #0891b2
}

.setting-list--day .neo-switch {
    background: rgba(15,23,42,.06);
    border-color: rgba(15,23,42,.09)
}

.setting-list--day .neo-switch.is-on {
    background: rgba(8,145,178,.16);
    border-color: rgba(8,145,178,.26)
}
