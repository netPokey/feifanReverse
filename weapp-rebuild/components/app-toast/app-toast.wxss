.app-toast-host {
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: center;
    justify-content: center;
    left: 20px;
    pointer-events: none;
    position: fixed;
    right: 20px;
    top: calc(80px + env(safe-area-inset-top));
    z-index: 9999
}

.app-toast-host--gauge {
    top: calc(24px + env(safe-area-inset-top))
}

.app-toast {
    -webkit-align-items: center;
    align-items: center;
    -webkit-animation: app-toast-in .22s ease-out both;
    animation: app-toast-in .22s ease-out both;
    background: rgba(0,0,0,.85);
    border: 1px solid hsla(0,0%,100%,.1);
    border-radius: 18px;
    box-shadow: 0 4px 25px rgba(0,0,0,.5);
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    gap: 8px;
    -webkit-justify-content: center;
    justify-content: center;
    max-width: 360px;
    min-height: 42px;
    overflow: hidden;
    padding: 10px 16px;
    position: relative;
    white-space: nowrap
}

.app-toast::after {
    -webkit-animation: app-toast-breath 1.6s ease-in-out infinite;
    animation: app-toast-breath 1.6s ease-in-out infinite;
    border: 1px solid;
    border-radius: 18px;
    content: "";
    inset: 0;
    opacity: .18;
    pointer-events: none;
    position: absolute
}

.app-toast.is-leaving {
    -webkit-animation: app-toast-out .18s ease-in both;
    animation: app-toast-out .18s ease-in both
}

.app-toast__mark {
    -webkit-align-items: center;
    align-items: center;
    -webkit-animation: app-toast-mark-pulse 2s cubic-bezier(.4,0,.6,1) infinite;
    animation: app-toast-mark-pulse 2s cubic-bezier(.4,0,.6,1) infinite;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    height: 15px;
    -webkit-justify-content: center;
    justify-content: center;
    width: 15px
}

.app-toast__mark-image {
    display: block;
    height: 15px;
    width: 15px
}

.app-toast__message {
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 1.5px;
    line-height: 1.25;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap
}

.app-toast--success {
    border-color: rgba(16,185,129,.4);
    box-shadow: 0 4px 25px rgba(16,185,129,.25);
    color: #34d399
}

.app-toast--error {
    border-color: rgba(239,68,68,.4);
    box-shadow: 0 4px 25px rgba(239,68,68,.25);
    color: #ef4444
}

.app-toast--info {
    border-color: rgba(0,240,255,.36);
    box-shadow: 0 4px 25px rgba(0,240,255,.18);
    color: #00f0ff
}

.app-toast--theme-day {
    background: hsla(0,0%,100%,.94);
    border-color: rgba(15,23,42,.08);
    box-shadow: 0 12px 34px rgba(15,23,42,.14),inset 0 1px 0 hsla(0,0%,100%,.9)
}

.app-toast--theme-day::after {
    opacity: .1
}

.app-toast--theme-day.app-toast--success {
    border-color: rgba(16,185,129,.32);
    box-shadow: 0 12px 34px rgba(16,185,129,.16),inset 0 1px 0 hsla(0,0%,100%,.9);
    color: #047857
}

.app-toast--theme-day.app-toast--error {
    border-color: rgba(220,38,38,.28);
    box-shadow: 0 12px 34px rgba(220,38,38,.14),inset 0 1px 0 hsla(0,0%,100%,.9);
    color: #dc2626
}

.app-toast--theme-day.app-toast--info {
    border-color: rgba(14,165,233,.3);
    box-shadow: 0 12px 34px rgba(14,165,233,.14),inset 0 1px 0 hsla(0,0%,100%,.9);
    color: #0284c7
}

@-webkit-keyframes app-toast-in {
    from {
        opacity: 0;
        -webkit-transform: translateY(-20px) scale(.95);
        transform: translateY(-20px) scale(.95)
    }

    to {
        opacity: 1;
        -webkit-transform: translateY(0) scale(1);
        transform: translateY(0) scale(1)
    }
}

@keyframes app-toast-in {
    from {
        opacity: 0;
        -webkit-transform: translateY(-20px) scale(.95);
        transform: translateY(-20px) scale(.95)
    }

    to {
        opacity: 1;
        -webkit-transform: translateY(0) scale(1);
        transform: translateY(0) scale(1)
    }
}

@-webkit-keyframes app-toast-out {
    from {
        opacity: 1;
        -webkit-transform: translateY(0) scale(1);
        transform: translateY(0) scale(1)
    }

    to {
        opacity: 0;
        -webkit-transform: translateY(-10px) scale(.95);
        transform: translateY(-10px) scale(.95)
    }
}

@keyframes app-toast-out {
    from {
        opacity: 1;
        -webkit-transform: translateY(0) scale(1);
        transform: translateY(0) scale(1)
    }

    to {
        opacity: 0;
        -webkit-transform: translateY(-10px) scale(.95);
        transform: translateY(-10px) scale(.95)
    }
}

@-webkit-keyframes app-toast-mark-pulse {
    0%,100% {
        opacity: 1
    }

    50% {
        opacity: .5
    }
}

@keyframes app-toast-mark-pulse {
    0%,100% {
        opacity: 1
    }

    50% {
        opacity: .5
    }
}

@-webkit-keyframes app-toast-breath {
    0%,100% {
        opacity: .12
    }

    50% {
        opacity: .34
    }
}

@keyframes app-toast-breath {
    0%,100% {
        opacity: .12
    }

    50% {
        opacity: .34
    }
}