@-webkit-keyframes bleStatusPulse {
    0%,100% {
        opacity: .78
    }

    50% {
        opacity: 1
    }
}

@keyframes bleStatusPulse {
    0%,100% {
        opacity: .78
    }

    50% {
        opacity: 1
    }
}

@-webkit-keyframes bleRadarSweep {
    0% {
        -webkit-transform: rotate(0deg);
        transform: rotate(0deg)
    }

    100% {
        -webkit-transform: rotate(1turn);
        transform: rotate(1turn)
    }
}

@keyframes bleRadarSweep {
    0% {
        -webkit-transform: rotate(0deg);
        transform: rotate(0deg)
    }

    100% {
        -webkit-transform: rotate(1turn);
        transform: rotate(1turn)
    }
}

@-webkit-keyframes bleSignalIn {
    0% {
        opacity: 0;
        -webkit-transform: scale(.42);
        transform: scale(.42)
    }

    35% {
        opacity: .72
    }

    100% {
        opacity: 0;
        -webkit-transform: scale(1.95);
        transform: scale(1.95)
    }
}

@keyframes bleSignalIn {
    0% {
