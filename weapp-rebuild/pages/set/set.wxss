.settings-group {
    margin-top: 24rpx
}

.settings-group:first-child {
    margin-top: 0
}

.group-panel {
    background: linear-gradient(145deg,rgba(20,28,44,.95),#0a0e16);
    border-color: rgba(148,163,184,.14);
    box-shadow: 0 22rpx 60rpx rgba(0,0,0,.48),inset 0 1rpx 0 hsla(0,0%,100%,.065);
    overflow: hidden;
    padding: 0
}

.group-panel__title {
    border-left: 4rpx solid rgba(125,211,252,.32);
    color: #a8b8cc;
    font-size: calc(24rpx * var(--app-font-scale));
    font-weight: 900;
    letter-spacing: 2rpx;
    line-height: 1;
    margin: 28rpx 28rpx 12rpx;
    padding: 0 4rpx 0 16rpx
}

.theme-action-grid__item {
    -webkit-align-items: center;
    align-items: center;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    gap: 24rpx;
    min-height: 118rpx;
    overflow: hidden;
    padding: 24rpx 28rpx;
    position: relative;
    transition: background .22s ease,opacity .18s ease,-webkit-transform .18s cubic-bezier(.2,.9,.22,1.18);
    transition: background .22s ease,opacity .18s ease,transform .18s cubic-bezier(.2,.9,.22,1.18);
    transition: background .22s ease,opacity .18s ease,transform .18s cubic-bezier(.2,.9,.22,1.18),-webkit-transform .18s cubic-bezier(.2,.9,.22,1.18)
}

.theme-action-grid__item::after {
    background: rgba(148,163,184,.12);
    bottom: 0;
    content: "";
    height: 1rpx;
    left: 28rpx;
    pointer-events: none;
    position: absolute;
    right: 28rpx
}

.theme-action-grid__item:active {
    background: linear-gradient(90deg,rgba(30,41,59,.6),rgba(15,23,42,.26),rgba(15,23,42,0));
    opacity: .92;
    -webkit-transform: scale(.992);
    transform: scale(.992)
}

.theme-action-grid__icon {
    -webkit-align-items: center;
    align-items: center;
    background: radial-gradient(circle at 36% 28%,hsla(0,0%,100%,.14),rgba(51,65,85,.34) 36%,rgba(8,12,22,.92) 78%);
    border: 1rpx solid rgba(148,163,184,.14);
    border-radius: 24rpx;
    box-shadow: inset 0 1rpx 0 hsla(0,0%,100%,.11);
    display: -webkit-flex;
    display: flex;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    height: 74rpx;
    -webkit-justify-content: center;
    justify-content: center;
    width: 74rpx
}

.theme-action-grid__icon--auto {
    background: radial-gradient(circle at 36% 28%,hsla(0,0%,100%,.13),rgba(109,40,217,.18) 36%,rgba(15,12,28,.9) 78%);
    border-color: rgba(168,85,247,.11)
}

.theme-action-grid__icon--font {
    background: radial-gradient(circle at 36% 28%,hsla(0,0%,100%,.13),rgba(56,96,126,.22) 36%,rgba(8,12,22,.9) 78%);
    border-color: rgba(125,211,252,.12)
}

.theme-action-grid__icon-image {
    display: block;
    height: 38rpx;
    width: 38rpx
}

.theme-action-grid__content {
    -webkit-flex: 1;
    flex: 1;
    min-width: 0
}

.theme-action-grid__head {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    gap: 12rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between
}

.theme-action-grid__name {
    color: rgba(248,250,252,.98);
    font-size: calc(27rpx * var(--app-font-scale));
    font-weight: 900;
    line-height: 1.25
}

.theme-action-grid__badge {
    -webkit-align-items: center;
    align-items: center;
    background: rgba(30,41,59,.58);
    border: 1rpx solid rgba(148,163,184,.14);
    border-radius: 18rpx;
    box-sizing: border-box;
    color: #9fb0c5;
    display: -webkit-flex;
    display: flex;
    font-size: calc(21rpx * var(--app-font-scale));
    font-weight: 600;
    height: 36rpx;
    -webkit-justify-content: center;
    justify-content: center;
    min-width: 64rpx;
    padding: 0 12rpx;
    white-space: nowrap
}

.theme-action-grid__desc {
    color: #8fa0b4;
    font-size: calc(23rpx * var(--app-font-scale));
    line-height: 1.4;
    margin-top: 8rpx
}

.font-size-card {
    border-top: 0
}

.font-size-card__head {
    border-bottom: 0;
    padding-bottom: 14rpx
}

.font-size-card__head::after {
    display: none
}

.font-size-slider {
    box-sizing: border-box;
    padding: 0 30rpx 28rpx 126rpx
}

.font-size-slider wx-slider {
    margin: 0
}

.font-size-slider__labels {
    -webkit-align-items: center;
    align-items: center;
    color: #8fa0b4;
    display: -webkit-flex;
    display: flex;
    font-size: calc(21rpx * var(--app-font-scale));
    font-weight: 900;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    line-height: 1;
    margin-top: 8rpx
}

.theme-action-grid__chevron {
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    height: 30rpx;
    opacity: .64;
    width: 30rpx
}

.theme-day .group-panel {
    background: linear-gradient(145deg,hsla(0,0%,100%,.96),rgba(236,254,255,.94));
    border-color: rgba(14,116,144,.16)
}

.theme-day .group-panel__title {
    border-left-color: rgba(8,145,178,.7);
    color: #334155
}

.theme-day .theme-action-grid__item::after {
    background: rgba(15,23,42,.07)
}

.theme-day .theme-action-grid__item:active {
    background: rgba(8,145,178,.055)
}

.theme-day .theme-action-grid__name {
    color: #0f172a
}

.theme-day .theme-action-grid__desc {
    color: #64748b
}

.theme-day .theme-action-grid__badge {
    background: rgba(8,145,178,.07);
    border-color: rgba(8,145,178,.16);
    color: #64748b
}

.theme-day .theme-action-grid__icon {
    background: rgba(8,145,178,.07);
    border-color: rgba(8,145,178,.14)
}

.theme-day .font-size-slider__labels {
    color: #64748b
}
