.automation-hero,.running-card {
    -webkit-align-items: center;
    align-items: center;
    background: radial-gradient(circle at 82% 16%,rgba(0,210,255,.14),transparent 220rpx),linear-gradient(145deg,rgba(20,28,46,.96),rgba(10,14,24,.99));
    border-color: rgba(148,226,255,.18);
    box-shadow: 0 22rpx 60rpx rgba(0,0,0,.32),0 0 32rpx rgba(0,210,255,.04),inset 0 1rpx 0 hsla(0,0%,100%,.07);
    display: -webkit-flex;
    display: flex;
    gap: 22rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    min-height: 128rpx
}

.tag.is-ready {
    background: linear-gradient(135deg,rgba(13,242,163,.1),rgba(0,240,255,.035));
    border-color: rgba(13,242,163,.18);
    box-shadow: 0 0 22rpx rgba(13,242,163,.09),inset 0 1rpx 0 hsla(0,0%,100%,.06);
    color: #0df2a3
}

.flow-card {
    background: linear-gradient(145deg,rgba(20,28,46,.96),rgba(10,14,24,.99));
    border-color: rgba(148,226,255,.16);
    box-shadow: 0 22rpx 60rpx rgba(0,0,0,.32),0 0 28rpx rgba(0,210,255,.04),inset 0 1rpx 0 hsla(0,0%,100%,.07);
    transition: border-color .22s ease,box-shadow .22s ease,-webkit-transform .18s cubic-bezier(.2,.9,.22,1.18);
    transition: transform .18s cubic-bezier(.2,.9,.22,1.18),border-color .22s ease,box-shadow .22s ease;
    transition: transform .18s cubic-bezier(.2,.9,.22,1.18),border-color .22s ease,box-shadow .22s ease,-webkit-transform .18s cubic-bezier(.2,.9,.22,1.18)
}

.flow-card:active {
    border-color: rgba(0,210,255,.12);
    box-shadow: 0 24rpx 66rpx rgba(0,0,0,.34),0 0 38rpx rgba(0,210,255,.055),inset 0 1rpx 0 hsla(0,0%,100%,.045);
    -webkit-transform: scale(.988);
    transform: scale(.988)
}

.flow-card__head {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    gap: 22rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between
}

.flow-card__head > wx-view:first-child {
    -webkit-flex: 1;
    flex: 1;
    min-width: 0
}

.flow-card__title {
    color: #f8fafc;
    font-size: calc(32rpx * var(--app-font-scale));
    font-weight: 900;
    line-height: 1.2
}

.flow-card__metrics {
    display: grid;
    gap: 18rpx;
    grid-template-columns: 180rpx minmax(0,1fr);
    margin: 24rpx 0
}

.flow-card__metrics > wx-view {
    background: radial-gradient(circle at 22% 24%,rgba(0,210,255,.1),transparent 112rpx),linear-gradient(145deg,rgba(26,36,56,.94),rgba(14,20,34,.98));
    border: 1rpx solid rgba(0,210,255,.16);
    border-radius: 22rpx;
    box-shadow: 0 0 18rpx rgba(0,210,255,.04),inset 0 1rpx 0 hsla(0,0%,100%,.06);
    box-sizing: border-box;
    min-height: 104rpx;
    padding: 18rpx
}

.flow-card__metric-value {
    color: #eaffff;
    font-size: calc(30rpx * var(--app-font-scale));
    font-weight: 900;
    line-height: 1.2;
    text-shadow: 0 0 18rpx rgba(0,210,255,.18),0 0 34rpx rgba(0,245,212,.08);
    word-break: break-all
}

.flow-card__metric-label {
    color: #8fa0b4;
    font-size: calc(22rpx * var(--app-font-scale));
    line-height: 1.2;
    margin-top: 8rpx
}

.log-panel {
    margin-top: 28rpx
}

.log-empty,.log-row {
    margin-top: 16rpx
}

.log-row {
    -webkit-align-items: center;
    align-items: center;
    -webkit-animation: automation-log-in .36s cubic-bezier(.2,.9,.22,1.08) both;
    animation: automation-log-in .36s cubic-bezier(.2,.9,.22,1.08) both;
    border-top: 1rpx solid rgba(148,226,255,.1);
    display: grid;
    gap: 16rpx;
    grid-template-columns: 74rpx minmax(0,1fr) 108rpx;
    min-height: 92rpx;
    padding: 16rpx 0
}

.log-row__time {
    color: #00f0ff;
    font-size: calc(22rpx * var(--app-font-scale));
    font-weight: 800;
    line-height: 1.2;
    text-shadow: 0 0 16rpx rgba(0,240,255,.18)
}

.log-row__page {
    min-width: 0
}

.log-row__name {
    color: #f8fafc;
    font-size: calc(25rpx * var(--app-font-scale));
    font-weight: 800;
    line-height: 1.25
}

.log-row__status {
    -webkit-align-items: center;
    align-items: center;
    background: rgba(20,28,44,.9);
    border: 1rpx solid rgba(148,226,255,.14);
    border-radius: 19rpx;
    box-sizing: border-box;
    color: #8fa0b4;
    display: -webkit-flex;
    display: flex;
    font-size: calc(20rpx * var(--app-font-scale));
    font-weight: 700;
    -webkit-justify-content: center;
    justify-content: center;
    min-height: 38rpx;
    overflow: hidden;
    padding: 0 12rpx
}

@-webkit-keyframes automation-log-in {
    0% {
        opacity: 0;
        -webkit-transform: translateY(14rpx);
        transform: translateY(14rpx)
    }

    100% {
        opacity: 1;
        -webkit-transform: translateY(0);
        transform: translateY(0)
    }
}

@keyframes automation-log-in {
    0% {
        opacity: 0;
        -webkit-transform: translateY(14rpx);
        transform: translateY(14rpx)
    }

    100% {
        opacity: 1;
        -webkit-transform: translateY(0);
        transform: translateY(0)
    }
}