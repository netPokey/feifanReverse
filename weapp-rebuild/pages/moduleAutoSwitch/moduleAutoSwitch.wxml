<view class="page theme-{{appTheme}} font-{{appFontSizeClass}} page-shell module-auto-page" style="{{appFontSizeStyle}}">
    <view class="page-titlebar page-titlebar--with-back" style="{{titlebarStyle}}">
        <view bindtap="back" class="page-titlebar__back">
            <image class="page-titlebar__back-icon" mode="aspectFit" src="{{backIconPath}}"></image>
        </view>
    </view>
    <view class="panel section module-auto-hero">
        <view>
            <view class="strong">模块启停</view>
            <view class="muted">配置本地自动策略，进入后可自动启用。</view>
        </view>
        <view class="tag {{connected?'is-ready':''}}">{{connected?'已连接':'未连接'}}</view>
    </view>
    <view class="panel section option-panel">
        <view bindtap="toggleOption" class="setting-row" data-key="autoEnableOnAuth">
            <view class="setting-row__copy">
                <view class="setting-row__title">进入后自动启用</view>
                <view class="setting-row__desc">蓝牙密码通过后发送模块总开关启用。</view>
            </view>
            <view class="neo-switch neo-switch--sm {{config.autoEnableOnAuth?'is-on':''}}">
                <view class="neo-switch__thumb"></view>
            </view>
        </view>
        <view bindtap="toggleOption" class="setting-row" data-key="disableOnAppHide">
            <view class="setting-row__copy">
                <view class="setting-row__title">退出时尝试停用</view>
                <view class="setting-row__desc">小程序隐藏或退出时，若仍在线则尝试发送模块总开关停用。</view>
            </view>
            <view class="neo-switch neo-switch--sm {{config.disableOnAppHide?'is-on':''}}">
                <view class="neo-switch__thumb"></view>
            </view>
        </view>
    </view>
</view>
<app-toast toast="{{__appToast}}"></app-toast>
<app-modal modal="{{__appModal}}"></app-modal>
