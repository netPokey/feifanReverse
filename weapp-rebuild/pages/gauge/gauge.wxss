.hud-greeting,.hud-notice {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: center;
    justify-content: center;
    left: 50%;
    position: absolute;
    -webkit-transform: translateX(-50%);
