@font-face {
    font-family: Orbitron;
    font-style: normal;
    font-weight: 900;
    src: url(data:font/truetype;charset=utf-8;base64,) format("truetype")
}

page {
    background: #000
}

.gauge,page {
    height: 100vh;
    overflow: hidden
}

.gauge {
    --hud-scale: 1;
    --hud-accent: #00f0ff;
    --hud-drive-accent: #0df2a3;
    --hud-range-accent: #00f0ff;
    --hud-temp-accent: #fa0;
    --hud-ring-outline: hsla(0,0%,100%,.035);
    --hud-ring-fill: rgba(3,6,12,.88);
    --hud-ring-mask-fill: #03060c;
    --hud-card-bg: rgba(15,23,42,.42);
    --hud-card-border: hsla(0,0%,100%,.04);
    --hud-font-sans: "Outfit","SF Pro Display","PingFang SC",-apple-system,BlinkMacSystemFont,"Helvetica Neue",sans-serif;
    --hud-font-mono: "Orbitron","SF Mono","DIN Alternate","DIN Condensed","Menlo",monospace;
    --hud-card-title-font: 4.13vh;
    --hud-card-label-font: 3.48vh;
    --hud-card-value-font: 6.56vh;
    --hud-badge-font: 4.62vh;
    --hud-gear-font: 5.91vh;
    --hud-speed-font: 18.79vh;
    --hud-speed-unit-font: 4.13vh;
    --hud-action-font: 3.24vh;
    --hud-action-tag-font: 2.43vh;
    --hud-portrait-card-title-font: 39rpx;
    --hud-portrait-card-label-font: 41rpx;
    --hud-portrait-card-value-font: 60rpx;
    --hud-portrait-badge-font: 55rpx;
    --hud-portrait-gear-font: 60rpx;
    --hud-portrait-speed-font: 168rpx;
    --hud-portrait-speed-unit-font: 44rpx;
    --hud-portrait-action-font: 44rpx;
    -webkit-font-smoothing: antialiased;
    background: #030508;
    bottom: 0;
    color: #f8fafc;
    font-family: var(--hud-font-sans);
    left: 0;
    letter-spacing: 0;
    min-height: 100vh;
    position: fixed;
    right: 0;
    top: 0;
    width: 100vw
}

.transition-preparing {
    opacity: 0;
    -webkit-transform: scale(.975);
    transform: scale(.975)
}

.transition-active {
    -webkit-animation: hudEntryTransition .48s cubic-bezier(.16,1,.3,1) both;
    animation: hudEntryTransition .48s cubic-bezier(.16,1,.3,1) both
}

.dashboard-hud {
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column
}

.layout-portrait.hud-style-neon {
    overflow-x: hidden;
    overflow-y: auto
}

.layout-portrait.hud-style-neon .hud-bottom-actions {
    pointer-events: auto
}

.hud-theme-racing {
    --hud-accent: #ff2a00;
    --hud-drive-accent: #ff4d00;
    --hud-range-accent: #ff2a00;
    --hud-temp-accent: #f80;
    --hud-ring-outline: hsla(0,0%,100%,.035);
    --hud-ring-mask-fill: #130303;
    --hud-card-bg: rgba(26,5,5,.58);
    --hud-card-border: rgba(255,42,0,.12);
    background: #0a0202
}

.hud-theme-minimal {
    --hud-accent: #fff;
    --hud-drive-accent: #ddd;
    --hud-range-accent: #fff;
    --hud-temp-accent: #999;
    --hud-ring-outline: hsla(0,0%,100%,.05);
    --hud-ring-mask-fill: #15161a;
    --hud-card-bg: rgba(26,28,34,.62);
    --hud-card-border: hsla(0,0%,100%,.06);
    background: #111112
}

.hud-theme-neon {
    --neon-accent: #0870d8;
    --neon-accent-rgb: 8,112,216;
    --neon-depth-rgb: 0,72,144;
    --hud-accent: #0870d8;
    --hud-drive-accent: #26c565;
    --hud-range-accent: #0870d8;
    --hud-temp-accent: #31c48d;
    --hud-ring-outline: rgba(var(--neon-accent-rgb),.72);
