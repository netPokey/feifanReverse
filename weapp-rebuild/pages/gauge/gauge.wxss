    background-size: 20px 20px;
    opacity: .25
}

.hud-radial {
    background: radial-gradient(circle at 50% 45%,rgba(0,240,255,.09),rgba(0,240,255,0) 42%),radial-gradient(circle at 12% 50%,rgba(13,242,163,.08),rgba(13,242,163,0) 28%),radial-gradient(circle at 88% 50%,rgba(243,156,18,.08),rgba(243,156,18,0) 28%);
    opacity: .7
}

.hud-theme-minimal .hud-grid,.hud-theme-racing .hud-grid {
    opacity: .04
}

.hud-theme-racing .hud-radial {
    background: radial-gradient(circle at 50% 45%,rgba(255,42,0,.15),rgba(255,42,0,0) 46%)
}

.hud-theme-minimal .hud-radial {
    background: radial-gradient(circle at 50% 45%,hsla(0,0%,100%,.07),hsla(0,0%,100%,0) 48%)
}

.hud-theme-neon .hud-grid {
    background-image: linear-gradient(rgba(var(--neon-accent-rgb),.025) 1rpx,transparent 1rpx),linear-gradient(90deg,rgba(var(--neon-accent-rgb),.025) 1rpx,transparent 1rpx);
    background-size: 28px 28px;
    opacity: .08
}

.hud-theme-neon .hud-radial {
    background: radial-gradient(circle at 50% 48%,rgba(var(--neon-accent-rgb),.18),rgba(var(--neon-accent-rgb),.035) 32%,rgba(var(--neon-accent-rgb),0) 52%),radial-gradient(circle at 7% 50%,rgba(var(--neon-accent-rgb),.06),rgba(var(--neon-accent-rgb),0) 34%),radial-gradient(circle at 93% 50%,rgba(255,170,0,.06),rgba(255,170,0,0) 34%),linear-gradient(180deg,#030508,#050a10);
    opacity: .82
}

.hud-blind {
    bottom: 0;
    height: 100vh;
    max-width: 26vw;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    top: 0;
    transition: opacity .2s ease;
    width: 112px;
    z-index: 11
}

.hud-blind.is-active {
    -webkit-animation: hudBlindPrototypePulse 1.5s ease-in-out infinite;
    animation: hudBlindPrototypePulse 1.5s ease-in-out infinite;
    opacity: 1
}

.hud-blind--left {
    background: linear-gradient(90deg,hsla(0,100%,84%,.9),hsla(0,91%,71%,.34) 45%,hsla(0,91%,71%,.1) 72%,hsla(0,91%,71%,0));
    box-shadow: 42px 0 118px hsla(0,91%,71%,.22);
    left: 0
}

.hud-blind--right {
    background: linear-gradient(270deg,hsla(0,100%,84%,.9),hsla(0,91%,71%,.34) 45%,hsla(0,91%,71%,.1) 72%,hsla(0,91%,71%,0));
    box-shadow: -42px 0 118px hsla(0,91%,71%,.22);
    right: 0
}

.hud-blind::before {
    bottom: 0;
    content: "";
    max-width: 54vw;
    opacity: .62;
    position: absolute;
    top: 0;
    width: 270px
}

.hud-blind--left::before {
    background: linear-gradient(90deg,hsla(0,100%,84%,.38),hsla(0,91%,71%,.2) 42%,hsla(0,91%,71%,.08) 64%,hsla(0,91%,71%,.025) 82%,hsla(0,91%,71%,0));
    left: 0
}

.hud-blind--right::before {
    background: linear-gradient(270deg,hsla(0,100%,84%,.38),hsla(0,91%,71%,.2) 42%,hsla(0,91%,71%,.08) 64%,hsla(0,91%,71%,.025) 82%,hsla(0,91%,71%,0));
    right: 0
}

.hud-blind__rail {
    display: none
}

.hud-topbar {
    -webkit-justify-content: space-between;
    justify-content: space-between;
    pointer-events: auto;
    position: absolute;
    z-index: 12
}

.hud-action,.hud-nav-btn,.hud-status,.hud-topbar,.hud-turn-signal {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex
}

.hud-action,.hud-nav-btn,.hud-status,.hud-turn-signal {
    box-sizing: border-box;
    -webkit-justify-content: center;
    justify-content: center;
