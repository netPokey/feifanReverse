.debug-terminal {
    background: linear-gradient(145deg,rgba(20,28,46,.96),rgba(10,14,24,.99));
    border-color: rgba(148,226,255,.16);
    box-shadow: 0 24rpx 64rpx rgba(0,0,0,.38),0 0 28rpx rgba(0,210,255,.04),inset 0 1rpx 0 hsla(0,0%,100%,.07);
    padding: 18rpx
}

.debug-terminal__head {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    gap: 20rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    margin-bottom: 14rpx;
    min-height: 70rpx
}

.debug-terminal__title {
    color: #f8fafc;
    font-size: calc(28rpx * var(--app-font-scale));
    font-weight: 900;
    line-height: 1.2
}

.debug-terminal__sub {
    color: #8fa0b4;
    font-size: calc(21rpx * var(--app-font-scale));
    line-height: 1.35;
    margin-top: 6rpx
}

.debug-terminal__badge {
    -webkit-align-items: center;
    align-items: center;
    background: linear-gradient(135deg,rgba(0,210,255,.14),rgba(0,245,212,.05));
    border: 1rpx solid rgba(0,210,255,.22);
    border-radius: 19rpx;
    box-shadow: 0 0 18rpx rgba(0,210,255,.1),inset 0 1rpx 0 hsla(0,0%,100%,.07);
    box-sizing: border-box;
    color: #00d2ff;
    display: -webkit-flex;
    display: flex;
    font-size: calc(19rpx * var(--app-font-scale));
    font-weight: 900;
    height: 38rpx;
    -webkit-justify-content: center;
    justify-content: center;
    width: 68rpx
}

.debug-log {
    background: radial-gradient(circle at 50% 0,rgba(0,210,255,.045),transparent 320rpx),linear-gradient(180deg,#010204,#02040a);
    border: 1rpx solid hsla(0,0%,100%,.026);
    border-radius: 24rpx;
    box-shadow: inset 0 8rpx 40rpx rgba(0,0,0,.84),0 0 28rpx rgba(0,210,255,.018);
    box-sizing: border-box;
    color: rgba(219,234,254,.84);
    font-family: Menlo,Consolas,monospace;
    font-size: calc(22rpx * var(--app-font-scale));
    height: 560rpx;
    line-height: 1.45;
    padding: 22rpx;
    text-shadow: 0 0 14rpx rgba(0,210,255,.07);
    width: 100%
}

.debug-command {
    background: linear-gradient(145deg,rgba(20,28,46,.94),rgba(10,14,24,.98));
    border-color: rgba(148,226,255,.14);
    padding: 20rpx
}

.debug-command__label {
    color: #8fa0b4;
    font-size: calc(22rpx * var(--app-font-scale));
    font-weight: 800;
    line-height: 1;
    margin-bottom: 12rpx
}
