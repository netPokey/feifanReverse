.item-row {
    margin-bottom: 16rpx
}

.item-row__head {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    gap: 20rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    margin-bottom: 18rpx
}

.item-row__head > wx-view:first-child {
    -webkit-flex: 1;
    flex: 1;
    min-width: 0
}

.picker-row {
    display: grid;
    gap: 16rpx;
    grid-template-columns: repeat(2,minmax(0,1fr))
}

.picker-cell {
    background: rgba(20,28,44,.92);
    border: 1rpx solid rgba(148,226,255,.14);
    border-radius: 22rpx;
    box-shadow: inset 0 1rpx 0 hsla(0,0%,100%,.06);
    box-sizing: border-box;
    min-height: 92rpx;
    padding: 18rpx
}

.picker-cell:active {
    opacity: .82
}

.picker-label {
    color: #8fa0b4;
    font-size: calc(22rpx * var(--app-font-scale));
    line-height: 1.2
}

.picker-value {
    color: #f8fafc;
    font-size: calc(26rpx * var(--app-font-scale));
    font-weight: 800;
    line-height: 1.25;
    margin-top: 8rpx;
    word-break: break-all
}

.item-actions {
    margin-top: 18rpx
}

.item-actions .btn {
    -webkit-flex: 1 1 188rpx;
    flex: 1 1 188rpx
}

.exec-strip {
    -webkit-align-items: center;
    align-items: center;
    background: rgba(0,240,255,.07);
    border: 1rpx solid rgba(0,240,255,.18);
    border-radius: 22rpx;
    box-sizing: border-box;
    color: #a7f3ff;
    display: -webkit-flex;
    display: flex;
    font-size: calc(24rpx * var(--app-font-scale));
    gap: 12rpx;
    line-height: 1.35;
    margin-bottom: 16rpx;
    min-height: 70rpx;
    padding: 16rpx 20rpx
}

.exec-strip--error {
    background: rgba(239,68,68,.1);
    border-color: hsla(0,91%,71%,.24);
    color: #fecaca
}

.exec-dot {
    background: currentColor;
    border-radius: 50%;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    height: 14rpx;
    width: 14rpx
}

.config-selector-page {
    background: #05070b;
    bottom: 0;
    color: #f8fafc;
    left: 0;
    overflow: hidden;
    position: fixed;
    right: 0;
    top: 0;
    z-index: 80
}

.config-selector-bg {
    background: radial-gradient(circle at 50% 0,rgba(0,240,255,.16),transparent 360rpx),linear-gradient(135deg,#07111e,#04070d 70%,#05070b);
    height: 420rpx;
    left: 0;
    position: absolute;
    right: 0;
    top: 0
}

.config-selector-header {
    gap: 18rpx;
    left: 24rpx;
    min-height: 108rpx;
    position: absolute;
    right: 24rpx;
    top: calc(76rpx + env(safe-area-inset-top))
}

.config-selector-back,.config-selector-header {
    -webkit-align-items: center;
    align-items: center;
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex
}

.config-selector-back {
    background: #0d1724;
    border: 1rpx solid rgba(0,240,255,.16);
    border-radius: 20rpx;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    height: 58rpx;
    -webkit-justify-content: center;
    justify-content: center;
    width: 58rpx
}

.config-option-row:active,.config-selector-action:active,.config-selector-back:active {
    opacity: .78
}

.config-selector-back__icon {
    display: block;
    height: 30rpx;
    width: 30rpx
}

.config-selector-heading {
    -webkit-flex: 1;
    flex: 1;
    min-width: 0
}

.config-selector-eyebrow {
    color: #00f0ff;
    font-size: calc(20rpx * var(--app-font-scale));
    font-weight: 900;
    letter-spacing: 6rpx;
    line-height: 1;
    margin-bottom: 8rpx
}

.config-selector-title {
    color: #f8fafc;
    font-size: calc(34rpx * var(--app-font-scale));
    font-weight: 900;
    line-height: 1.18
}

.config-selector-sub {
    color: #93a4ba;
    font-size: calc(23rpx * var(--app-font-scale));
    line-height: 1.35;
    margin-top: 10rpx
}

.config-selector-current {
    -webkit-align-items: center;
    align-items: center;
    background: #0d1724;
    border: 1rpx solid rgba(0,240,255,.16);
    border-radius: 28rpx;
    box-shadow: 0 24rpx 60rpx rgba(0,0,0,.22),inset 0 1rpx 0 hsla(0,0%,100%,.1);
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    gap: 20rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    left: 24rpx;
    min-height: 118rpx;
    overflow: hidden;
    padding: 22rpx 24rpx;
    position: absolute;
    right: 24rpx;
    top: calc(300rpx + env(safe-area-inset-top))
}

.config-selector-current__label {
    color: #8fa0b4;
    font-size: calc(22rpx * var(--app-font-scale));
    line-height: 1
}

.config-selector-current__value {
    color: #f8fafc;
    font-size: calc(30rpx * var(--app-font-scale));
    font-weight: 800;
    line-height: 1.24;
    margin-top: 10rpx;
    word-break: break-all
}

.config-selector-current__tag {
    -webkit-align-items: center;
    align-items: center;
    background: rgba(0,240,255,.08);
    border: 1rpx solid rgba(0,240,255,.22);
    border-radius: 22rpx;
    box-sizing: border-box;
    color: #00f0ff;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    font-size: calc(22rpx * var(--app-font-scale));
    font-weight: 800;
    height: 44rpx;
    -webkit-justify-content: center;
    justify-content: center;
    min-width: 82rpx;
    padding: 0 16rpx;
    white-space: nowrap
}

.config-selector-page {
    bottom: calc(142rpx + env(safe-area-inset-bottom));
    box-sizing: border-box;
    left: 24rpx;
    overflow: hidden;
    position: absolute;
    right: auto;
    top: calc(448rpx + env(safe-area-inset-top));
    width: 702rpx
}

.config-selector-list {
    box-sizing: border-box;
    min-height: 100%;
    padding: 0 0 26rpx;
    width: 100%
}

.config-option-row {
    -webkit-align-items: center;
    align-items: center;
    background: #111827;
    border: 1rpx solid #263142;
    border-radius: 26rpx;
    box-shadow: 0 18rpx 42rpx rgba(0,0,0,.16),inset 0 1rpx 0 hsla(0,0%,100%,.08);
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    gap: 20rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    margin-bottom: 16rpx;
    min-height: 104rpx;
    overflow: hidden;
    padding: 20rpx 42rpx 20rpx 22rpx;
    width: 100%
}

.config-option-row.is-selected {
    background: #0d2832;
    border-color: rgba(0,240,255,.38);
    box-shadow: 0 18rpx 48rpx rgba(0,240,255,.12),inset 0 1rpx 0 hsla(0,0%,100%,.12)
}

.config-option-main {
    -webkit-flex: 1;
    flex: 1;
    min-width: 0
}

.config-option-name {
    color: #f8fafc;
    font-size: calc(29rpx * var(--app-font-scale));
    font-weight: 800;
    line-height: 1.25;
    word-break: break-all
}

.config-option-sub {
    color: #8fa0b4;
    font-size: calc(22rpx * var(--app-font-scale));
    line-height: 1.25;
    margin-top: 8rpx
}

.config-option-arrow {
    border-right: 4rpx solid #64748b;
    border-top: 4rpx solid #64748b;
    box-sizing: border-box;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    height: 20rpx;
    margin-right: 4rpx;
    -webkit-transform: rotate(45deg);
    transform: rotate(45deg);
    width: 20rpx
}

.config-option-check {
    color: #00f0ff;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    font-size: calc(34rpx * var(--app-font-scale));
    font-weight: 900;
    min-width: 58rpx;
    padding-right: 4rpx;
    text-align: right
}

.config-selector-footer {
    background: #05070b;
    border-top: 1rpx solid #1f2937;
    bottom: 0;
    box-shadow: 0 -24rpx 60rpx rgba(0,0,0,.24);
    gap: 16rpx;
    left: 0;
    min-height: calc(122rpx + env(safe-area-inset-bottom));
    padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
    position: absolute;
    right: 0
}

.config-selector-action,.config-selector-footer {
    -webkit-align-items: center;
    align-items: center;
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex
}

.config-selector-action {
    border-radius: 24rpx;
    font-size: calc(27rpx * var(--app-font-scale));
    font-weight: 800;
    height: 74rpx;
    -webkit-justify-content: center;
    justify-content: center;
    line-height: 1;
    min-width: 132rpx;
    padding: 0 24rpx;
    white-space: nowrap
}

.config-selector-spacer {
    -webkit-flex: 1;
    flex: 1
}

.config-selector-action--ghost {
    background: #111827;
    border: 1rpx solid #263142;
    color: #cbd5e1
}

.config-selector-action--attempt {
    background: #111827;
    border: 1rpx solid rgba(0,240,255,.18);
    color: #00f0ff
}

.config-selector-action--save {
    background: linear-gradient(135deg,#00f0ff,#0df2a3);
    box-shadow: 0 14rpx 30rpx rgba(0,240,255,.18),inset 0 1rpx 0 hsla(0,0%,100%,.32);
    color: #031014
}

.config-selector-action.is-disabled {
    background: #0b111d;
    border: 1rpx solid #1e293b;
    box-shadow: none;
    color: #657386;
    opacity: .72
}
