.firmware-summary {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    gap: 22rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    min-height: 118rpx
}

.tag.is-ready {
    background: rgba(13,242,163,.08);
    border-color: rgba(13,242,163,.18);
    color: #0df2a3
}

.device-info-panel {
    padding: 8rpx 24rpx
}

.info-row {
    -webkit-align-items: center;
    align-items: center;
    border-bottom: 1rpx solid rgba(148,226,255,.1);
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    gap: 20rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    min-height: 78rpx;
    padding: 16rpx 0
}

.info-row:last-child {
    border-bottom: 0
}

.info-label {
    color: #8fa0b4;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    font-size: calc(23rpx * var(--app-font-scale));
    line-height: 1.3
}

.info-value {
    color: #f8fafc;
    font-size: calc(25rpx * var(--app-font-scale));
    font-weight: 700;
    line-height: 1.3;
    min-width: 0;
    text-align: right;
    word-break: break-all
}

.diagnostic-warning {
    background: rgba(245,158,11,.08);
    border-color: rgba(245,158,11,.28)
}

.diagnostic-warning__title {
    color: #fbbf24;
    font-size: calc(26rpx * var(--app-font-scale));
    font-weight: 800;
    line-height: 1.25
}

.diagnostic-warning__text {
    color: #fde68a;
    font-size: calc(23rpx * var(--app-font-scale));
    line-height: 1.45;
    margin-top: 10rpx
}

.diagnostic-panel {
    padding: 24rpx
}

.diagnostic-panel__head {
    -webkit-align-items: flex-start;
    align-items: flex-start;
    display: -webkit-flex;
    display: flex;
    gap: 18rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    margin-bottom: 12rpx
}

.diagnostic-row {
    border-bottom: 1rpx solid rgba(148,226,255,.08);
    display: grid;
    gap: 18rpx;
    grid-template-columns: 170rpx minmax(0,1fr);
    padding: 14rpx 0
}

.diagnostic-row:last-of-type {
    border-bottom: 0
}

.diagnostic-value {
    color: #dce9f4;
    font-size: calc(21rpx * var(--app-font-scale));
    line-height: 1.45;
    min-width: 0;
    text-align: right;
    word-break: break-all
}

.diagnostic-actions {
    display: grid;
    gap: 12rpx;
    grid-template-columns: repeat(3,minmax(0,1fr));
    margin-top: 22rpx
}

.diagnostic-button {
    font-size: calc(22rpx * var(--app-font-scale));
    min-height: 68rpx;
    width: 100%
}

.diagnostic-result {
    background: rgba(2,8,23,.72);
    border: 1rpx solid rgba(148,226,255,.12);
    border-radius: 16rpx;
    color: #cbd5e1;
    font-size: calc(20rpx * var(--app-font-scale));
    line-height: 1.5;
    margin-top: 18rpx;
    max-height: 420rpx;
    overflow: auto;
    padding: 18rpx;
    white-space: pre-wrap;
    word-break: break-all
}

.capture-panel {
    padding: 24rpx
}

.capture-row {
    -webkit-align-items: flex-start;
    align-items: flex-start;
    display: -webkit-flex;
    display: flex;
    gap: 14rpx;
    min-height: 54rpx;
    padding: 8rpx 0
}

.capture-dot {
    background: #38bdf8;
    border-radius: 50%;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    height: 10rpx;
    margin-top: 15rpx;
    width: 10rpx
}

.capture-text {
    color: #dce9f4;
    font-size: calc(22rpx * var(--app-font-scale));
    line-height: 1.45;
    min-width: 0
}

.firmware-section {
    display: grid;
    gap: 16rpx;
    grid-template-columns: repeat(2,minmax(0,1fr))
}

.firmware-card {
    min-width: 0
}

.firmware-card__head {
    -webkit-align-items: flex-start;
    align-items: flex-start;
    display: -webkit-flex;
    display: flex;
    gap: 16rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    min-height: 82rpx
}

.firmware-card__title {
    color: #f8fafc;
    font-size: calc(28rpx * var(--app-font-scale));
    font-weight: 800;
    line-height: 1.2
}

.firmware-card__sub {
    color: #8fa0b4;
    font-size: calc(22rpx * var(--app-font-scale));
    line-height: 1.3;
    margin-top: 8rpx
}

.firmware-card__versions {
    display: grid;
    gap: 14rpx;
    grid-template-columns: repeat(2,minmax(0,1fr));
    margin-top: 20rpx
}

.firmware-version {
    color: #dce9f4;
    font-size: calc(25rpx * var(--app-font-scale));
    font-weight: 800;
    line-height: 1.2;
    margin-top: 8rpx;
    word-break: break-all
}

.firmware-card__note {
    background: rgba(15,23,42,.55);
    border: 1rpx solid rgba(148,163,184,.12);
    border-radius: 18rpx;
    color: #94a3b8;
    font-size: calc(22rpx * var(--app-font-scale));
    line-height: 1.45;
    margin-top: 18rpx;
    padding: 14rpx
}

.firmware-card__actions {
    display: grid;
    gap: 12rpx;
    grid-template-columns: repeat(2,minmax(0,1fr));
    margin-top: 22rpx
}

.firmware-card__button {
    width: 100%
}

.firmware-card__button.is-disabled {
    opacity: .52
}

.tag--warn {
    background: rgba(245,158,11,.13);
    border-color: rgba(245,158,11,.25);
    color: #fbbf24
}
