@font-face {
    font-family: Orbitron;
    font-style: normal;
    font-weight: 900;
    src: url(data:font/truetype;charset=utf-8;base64,) format("truetype")
}

.index-page {
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    height: 100vh;
    -webkit-justify-content: flex-start;
    justify-content: flex-start;
    min-height: 100vh;
    overflow-x: hidden;
    overflow-y: hidden;
    padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
    padding-top: var(--page-shell-top,calc(22rpx + env(safe-area-inset-top)))
}

.index-page.is-access-locked .health-card,.index-page.is-access-locked .home-feature {
    opacity: .16;
    pointer-events: none;
    -webkit-transform: scale(.985);
    transform: scale(.985)
}

.access-lock {
    -webkit-align-items: center;
    align-items: center;
    background: radial-gradient(circle at 50% 18%,rgba(30,41,59,.34) 0,rgba(8,13,24,.98) 48%,#03050a 100%);
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    inset: 0;
    -webkit-justify-content: center;
    justify-content: center;
    padding: calc(96rpx + var(--page-safe-top, 0rpx)) 48rpx calc(72rpx + env(safe-area-inset-bottom));
    position: fixed;
    z-index: 9600
}

.access-lock__scrim {
    background: linear-gradient(180deg,rgba(3,6,12,.94),rgba(3,6,12,.985));
    inset: 0;
    pointer-events: none;
    position: absolute
}

.access-lock::after,.access-lock::before {
    border-radius: 999rpx;
    content: "";
    left: 50%;
    pointer-events: none;
    position: absolute;
    top: 18%
}

.access-lock::before {
    background: radial-gradient(circle,rgba(125,211,252,.1) 0,rgba(125,211,252,.024) 46%,rgba(125,211,252,0) 76%);
    height: 420rpx;
    margin-left: -210rpx;
    opacity: .54;
    width: 420rpx
}

.access-lock::after {
    background: radial-gradient(circle,rgba(94,234,212,.04) 0,rgba(94,234,212,.012) 42%,rgba(94,234,212,0) 72%);
    height: 680rpx;
    margin-left: -340rpx;
    opacity: .38;
    width: 680rpx
}

.access-lock__panel {
    -webkit-flex-direction: column;
    flex-direction: column;
    max-width: 640rpx;
    text-align: center;
    width: 100%;
    z-index: 1
}

.access-lock__icon,.access-lock__panel {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    position: relative
}

.access-lock__icon {
    background: linear-gradient(145deg,rgba(30,41,59,.78),rgba(8,13,24,.94));
    border: 2rpx solid rgba(125,211,252,.2);
    border-radius: 34rpx;
    box-shadow: 0 22rpx 56rpx rgba(0,0,0,.34),inset 0 1rpx 0 hsla(0,0%,100%,.08);
    height: 136rpx;
    -webkit-justify-content: center;
    justify-content: center;
    width: 136rpx
}

.access-lock__icon::after {
    border: 1rpx solid rgba(148,163,184,.14);
    border-radius: 34rpx;
    content: "";
    inset: -2rpx;
    opacity: .55;
    position: absolute
}

.access-lock__shackle {
    border: 7rpx solid #8bd5e6;
    border-bottom: 0;
    border-radius: 22rpx 22rpx 0 0;
    box-sizing: border-box;
    height: 34rpx;
    left: 50%;
    margin-left: -21rpx;
    position: absolute;
    top: 42rpx;
    width: 42rpx
}

.access-lock__page {
    border: 7rpx solid #8bd5e6;
    border-radius: 8rpx;
    box-shadow: none;
    box-sizing: border-box;
    height: 40rpx;
    margin-top: 34rpx;
    width: 54rpx
}

.access-lock__title {
    color: #f8fafc;
    font-size: calc(35rpx * var(--app-font-scale));
    font-weight: 950;
    letter-spacing: 2rpx;
    line-height: 1.18;
    margin-top: 62rpx;
    text-shadow: none
}

.access-lock__subtitle {
    color: #95a3b5;
    font-size: calc(22rpx * var(--app-font-scale));
    font-weight: 800;
    letter-spacing: 1rpx;
    line-height: 1.5;
    margin-top: 26rpx
}

.access-lock__dots {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    gap: 34rpx;
    -webkit-justify-content: center;
    justify-content: center;
    margin-top: 60rpx
}

.access-lock__dot {
    background: transparent;
    border: 6rpx solid rgba(148,163,184,.2);
    border-radius: 999rpx;
    box-sizing: border-box;
    height: 28rpx;
    transition: all .18s ease;
