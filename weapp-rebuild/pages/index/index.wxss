}

.access-lock__dot.is-active {
    background: rgba(125,211,252,.32);
    border-color: rgba(125,211,252,.56);
    box-shadow: none
}

.access-lock__field {
    -webkit-align-items: center;
    align-items: center;
    background: hsla(0,0%,100%,.045);
    border: 1rpx solid rgba(148,163,184,.14);
    border-radius: 999rpx;
    box-shadow: inset 0 1rpx 0 hsla(0,0%,100%,.05),0 16rpx 42rpx rgba(0,0,0,.2);
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    margin-top: 34rpx;
    min-height: 82rpx;
    padding: 0 28rpx;
    width: 100%
}

.access-lock__input {
    caret-color: #7dd3fc;
    color: #e0faff;
    font-size: calc(26rpx * var(--app-font-scale));
    font-weight: 900;
    letter-spacing: 2rpx;
    min-height: 82rpx;
    text-align: center;
    width: 100%
}

.access-lock__placeholder {
    color: rgba(148,163,184,.55)
}

.access-lock__error {
    color: #fb7185;
    font-size: calc(22rpx * var(--app-font-scale));
    font-weight: 900;
    margin-top: 24rpx;
    min-height: 32rpx
}

.access-lock__actions {
    margin-top: 48rpx;
    position: relative;
    width: 100%;
    z-index: 3
}

.access-lock__button {
    -webkit-align-items: center;
    align-items: center;
    background: linear-gradient(135deg,#7dd3fc,#8be8df);
    border-radius: 999rpx;
    box-shadow: 0 20rpx 48rpx rgba(0,0,0,.24),inset 0 1rpx 0 hsla(0,0%,100%,.3);
    color: #031014;
    display: -webkit-flex;
    display: flex;
    font-size: calc(24rpx * var(--app-font-scale));
    font-weight: 950;
    -webkit-justify-content: center;
    justify-content: center;
    min-height: 72rpx
}

.access-lock__button:active {
    opacity: .9;
    -webkit-transform: scale(.97);
    transform: scale(.97)
}

.access-lock__button.is-disabled {
    background: hsla(0,0%,100%,.045);
    border: 1rpx solid hsla(0,0%,100%,.065);
    box-shadow: none;
    color: rgba(148,163,184,.82)
}

.access-lock__button.is-ready {
    -webkit-animation: access-lock-ready 1.6s ease-in-out infinite;
    animation: access-lock-ready 1.6s ease-in-out infinite
}

.theme-day .access-lock {
    background: radial-gradient(circle at 50% 18%,rgba(8,145,178,.12) 0,rgba(236,254,255,.985) 45%,#f8fafc 100%)
}

.theme-day .access-lock__scrim {
