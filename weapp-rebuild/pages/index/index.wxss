    display: grid;
    gap: 16rpx;
    grid-template-columns: repeat(2,minmax(0,1fr))
}

.home-shortcut-card {
    background: linear-gradient(145deg,rgba(26,36,58,.96),rgba(16,22,38,.98));
    border: 1rpx solid rgba(148,163,184,.16);
    border-radius: 28rpx;
    box-shadow: 0 16rpx 48rpx rgba(0,0,0,.32),inset 0 1rpx 0 hsla(0,0%,100%,.075);
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    height: auto;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    min-height: 160rpx;
    overflow: visible;
    padding: 22rpx;
    position: relative;
    transition: border-color .22s ease,box-shadow .22s ease,opacity .22s ease,-webkit-transform .18s cubic-bezier(.2,.9,.22,1.18);
    transition: transform .18s cubic-bezier(.2,.9,.22,1.18),border-color .22s ease,box-shadow .22s ease,opacity .22s ease;
    transition: transform .18s cubic-bezier(.2,.9,.22,1.18),border-color .22s ease,box-shadow .22s ease,opacity .22s ease,-webkit-transform .18s cubic-bezier(.2,.9,.22,1.18)
}

.home-shortcut-card:active {
    -webkit-transform: scale(.965);
    transform: scale(.965)
}

.home-shortcut-card.is-disabled {
    opacity: .72
}

