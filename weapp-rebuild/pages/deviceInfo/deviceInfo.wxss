.device-summary {
    display: grid;
    gap: 18rpx;
    grid-template-columns: 72rpx minmax(0,1fr) auto;
    min-height: 118rpx
}

.device-summary,.device-summary__icon {
    -webkit-align-items: center;
    align-items: center
}

.device-summary__icon {
    background: rgba(0,240,255,.12);
    border: 1rpx solid rgba(0,240,255,.24);
    border-radius: 22rpx;
    display: -webkit-flex;
    display: flex;
    height: 72rpx;
    -webkit-justify-content: center;
    justify-content: center;
    width: 72rpx
}

.device-summary__image {
    height: 42rpx;
    width: 42rpx
}

.device-summary__page {
    min-width: 0
}

.tag.is-ready {
    background: rgba(13,242,163,.08);
    border-color: rgba(13,242,163,.18);
    color: #0df2a3
}

.info-section {
    margin-bottom: 26rpx
}

.section-title {
    color: #dce9f4;
    font-size: calc(25rpx * var(--app-font-scale));
    font-weight: 800;
    letter-spacing: 1rpx;
    line-height: 1.2;
    margin: 0 0 16rpx
}

.info-panel {
    padding: 8rpx 24rpx
}

.info-row {
    -webkit-align-items: center;
    align-items: center;
    border-bottom: 1rpx solid rgba(148,226,255,.1);
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    gap: 20rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    min-height: 78rpx;
    padding: 16rpx 0
}

.info-row:last-child {
    border-bottom: 0
}

.info-label {
    color: #8fa0b4;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    font-size: calc(23rpx * var(--app-font-scale));
    line-height: 1.3
}

.info-value {
    color: #f8fafc;
    font-size: calc(25rpx * var(--app-font-scale));
    font-weight: 700;
    line-height: 1.3;
    min-width: 0;
    text-align: right;
    word-break: break-all
}
