@-webkit-keyframes bodyPartPulse {
    0% {
        box-shadow: 0 0 18rpx rgba(0,240,255,.14);
        opacity: .72
    }

    45% {
        box-shadow: 0 0 52rpx rgba(0,240,255,.44),0 0 78rpx rgba(13,242,163,.14);
        opacity: 1
    }

    68% {
        box-shadow: 0 0 24rpx rgba(0,240,255,.18);
        opacity: .86
    }

    100% {
        opacity: 1
    }
}

@keyframes bodyPartPulse {
    0% {
        box-shadow: 0 0 18rpx rgba(0,240,255,.14);
        opacity: .72
    }

    45% {
        box-shadow: 0 0 52rpx rgba(0,240,255,.44),0 0 78rpx rgba(13,242,163,.14);
        opacity: 1
    }

    68% {
        box-shadow: 0 0 24rpx rgba(0,240,255,.18);
        opacity: .86
    }

    100% {
        opacity: 1
    }
}

@-webkit-keyframes bodyBeaconPulse {
    0%,100% {
        opacity: .18;
        -webkit-transform: scale(.86);
        transform: scale(.86)
    }

    50% {
        opacity: .48;
        -webkit-transform: scale(1.08);
        transform: scale(1.08)
    }
}

@keyframes bodyBeaconPulse {
    0%,100% {
        opacity: .18;
        -webkit-transform: scale(.86);
        transform: scale(.86)
    }

    50% {
        opacity: .48;
        -webkit-transform: scale(1.08);
        transform: scale(1.08)
    }
}

