.body-mirror {
    background: transparent;
    height: 28rpx;
    position: absolute;
    top: 174rpx;
    -webkit-transform-origin: center;
    transform-origin: center;
    transition: all .3s ease;
    width: 44rpx
}

.body-mirror::after,.body-mirror::before {
    content: "";
    pointer-events: none;
    position: absolute;
    transition: inherit
}

.body-mirror::before {
    background: #00d2ff;
    box-shadow: 0 0 28rpx rgba(0,210,255,.24);
    inset: 0
}

.body-mirror::after {
    background: #151b28;
    inset: 4rpx
}

.body-mirror--left {
    left: 42rpx
}

.body-mirror--right {
    right: 42rpx
}

.body-mirror--left::after,.body-mirror--left::before {
    -webkit-clip-path: polygon(100% 0,0 28%,8% 100%,100% 62%);
    clip-path: polygon(100% 0,0 28%,8% 100%,100% 62%)
}

.body-mirror--right::after,.body-mirror--right::before {
    -webkit-clip-path: polygon(0 0,100% 28%,92% 100%,0 62%);
    clip-path: polygon(0 0,100% 28%,92% 100%,0 62%)
}

.body-mirror--left.is-folded {
    height: 32rpx;
    left: 76rpx;
    width: 22rpx
}

.body-mirror--right.is-folded {
    height: 32rpx;
    right: 76rpx;
    width: 22rpx
}

.body-mirror--left.is-folded::after,.body-mirror--left.is-folded::before {
    -webkit-clip-path: polygon(38% 0,0 66%,100% 100%);
    clip-path: polygon(38% 0,0 66%,100% 100%)
}

.body-mirror--right.is-folded::after,.body-mirror--right.is-folded::before {
    -webkit-clip-path: polygon(62% 0,100% 66%,0 100%);
    clip-path: polygon(62% 0,100% 66%,0 100%)
}

