.group-panel {
    -webkit-animation: group-panel-in .48s cubic-bezier(.2,.9,.22,1.08) both;
    animation: group-panel-in .48s cubic-bezier(.2,.9,.22,1.08) both;
    background: linear-gradient(145deg,rgba(20,28,44,.95),#0a0e16);
    border-color: rgba(148,163,184,.14);
    box-shadow: 0 22rpx 60rpx rgba(0,0,0,.48),inset 0 1rpx 0 hsla(0,0%,100%,.065);
    margin-top: 24rpx
}

.group-panel:first-child {
    margin-top: 0
}

.group-panel__title {
    border-left: 4rpx solid rgba(125,211,252,.32);
    color: #a8b8cc;
    font-size: calc(24rpx * var(--app-font-scale));
    font-weight: 900;
    letter-spacing: 2rpx;
    line-height: 1;
    margin-bottom: 16rpx;
    padding: 0 4rpx 0 16rpx
}

.access-mode-modal {
    -webkit-align-items: center;
    align-items: center;
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    inset: 0;
    -webkit-justify-content: center;
    justify-content: center;
    padding: 56rpx 44rpx calc(72rpx + env(safe-area-inset-bottom));
    position: fixed;
    z-index: 9800
}

.access-mode-modal__mask {
    background: radial-gradient(circle at 50% 24%,rgba(125,211,252,.07),rgba(125,211,252,0) 34%),rgba(0,0,0,.82);
    inset: 0;
    position: absolute
}

.access-mode-modal__panel {
    background: linear-gradient(145deg,rgba(14,21,31,.98),rgba(3,6,12,.99));
    border: 1rpx solid rgba(148,163,184,.14);
    border-radius: 42rpx;
    box-shadow: 0 36rpx 120rpx rgba(0,0,0,.7),inset 0 1rpx 0 hsla(0,0%,100%,.06);
    box-sizing: border-box;
    max-width: 640rpx;
    overflow: hidden;
    padding: 58rpx 48rpx 42rpx;
    position: relative;
    text-align: center;
    width: 100%;
    z-index: 1
}

.access-mode-modal__halo {
    -webkit-animation: access-mode-halo 2.6s ease-in-out infinite;
    animation: access-mode-halo 2.6s ease-in-out infinite;
    background: radial-gradient(circle,rgba(125,211,252,.1),rgba(125,211,252,.024) 48%,rgba(125,211,252,0) 74%);
    border-radius: 999rpx;
    height: 480rpx;
    left: 50%;
    margin-left: -240rpx;
    pointer-events: none;
    position: absolute;
    top: -180rpx;
    width: 480rpx
}

.access-mode-modal__icon {
    -webkit-align-items: center;
    align-items: center;
    background: linear-gradient(145deg,rgba(30,41,59,.8),rgba(8,13,24,.94));
    border: 1rpx solid rgba(125,211,252,.16);
    border-radius: 28rpx;
    box-shadow: inset 0 1rpx 0 hsla(0,0%,100%,.08);
    display: -webkit-flex;
    display: flex;
    height: 96rpx;
    -webkit-justify-content: center;
    justify-content: center;
    margin: 0 auto;
    width: 96rpx
}

.access-mode-modal__fingerprint {
    border: 6rpx solid rgba(125,211,252,.58);
    border-bottom-color: transparent;
    border-radius: 26rpx 26rpx 18rpx 18rpx;
    box-sizing: border-box;
    height: 58rpx;
    position: relative;
    width: 46rpx
}

.access-mode-modal__fingerprint::after,.access-mode-modal__fingerprint::before {
    border: 4rpx solid rgba(125,211,252,.46);
    border-bottom-color: transparent;
    box-sizing: border-box;
    content: "";
    left: 50%;
    position: absolute
}

.access-mode-modal__fingerprint::before {
    border-radius: 18rpx 18rpx 12rpx 12rpx;
    height: 36rpx;
    margin-left: -14rpx;
    top: 9rpx;
    width: 28rpx
}

.access-mode-modal__fingerprint::after {
    border-radius: 10rpx;
    height: 24rpx;
    margin-left: -6rpx;
    top: 20rpx;
    width: 12rpx
}

.access-mode-modal__title {
    color: #f8fafc;
    font-size: calc(34rpx * var(--app-font-scale));
    font-weight: 950;
    letter-spacing: 1rpx;
    line-height: 1.2;
    margin-top: 34rpx;
    position: relative
}

.access-mode-modal__subtitle {
    color: rgba(148,163,184,.74);
    font-size: calc(22rpx * var(--app-font-scale));
    font-weight: 800;
    line-height: 1.45;
    margin-top: 16rpx;
    position: relative
}

.access-mode-modal__dots {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    gap: 24rpx;
    -webkit-justify-content: center;
    justify-content: center;
    margin-top: 42rpx;
    position: relative
}

.access-mode-modal__dot {
    border: 5rpx solid rgba(148,163,184,.22);
    border-radius: 999rpx;
    box-sizing: border-box;
    height: 22rpx;
    width: 22rpx
}

.access-mode-modal__dot.is-active {
    background: rgba(125,211,252,.32);
    border-color: rgba(125,211,252,.58);
    box-shadow: none
}

.access-mode-modal__field {
    -webkit-align-items: center;
    align-items: center;
    background: hsla(0,0%,100%,.045);
    border: 1rpx solid rgba(148,163,184,.14);
    border-radius: 999rpx;
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    margin-top: 32rpx;
    min-height: 82rpx;
    padding: 0 28rpx;
    position: relative
}

.access-mode-modal__input {
    caret-color: #7dd3fc;
    color: #e0faff;
    font-size: calc(26rpx * var(--app-font-scale));
    font-weight: 900;
    letter-spacing: 2rpx;
    min-height: 82rpx;
    text-align: center;
    width: 100%
}

.access-mode-modal__placeholder {
    color: rgba(148,163,184,.58)
}

.access-mode-modal__error {
    color: #fb7185;
    font-size: calc(22rpx * var(--app-font-scale));
    font-weight: 900;
    margin-top: 20rpx;
    min-height: 34rpx
}

.access-mode-modal__actions {
    display: grid;
    gap: 18rpx;
    grid-template-columns: repeat(2,minmax(0,1fr));
    margin-top: 34rpx
}

.access-mode-modal__button {
    -webkit-align-items: center;
    align-items: center;
    border-radius: 999rpx;
    display: -webkit-flex;
    display: flex;
    font-size: calc(24rpx * var(--app-font-scale));
    font-weight: 950;
    -webkit-justify-content: center;
    justify-content: center;
    min-height: 74rpx
}

.access-mode-modal__button:active {
    -webkit-transform: scale(.97);
    transform: scale(.97)
}

.access-mode-modal__button--cancel {
    background: hsla(0,0%,100%,.052);
    border: 1rpx solid hsla(0,0%,100%,.08);
    color: #cbd5e1
}

.access-mode-modal__button--confirm {
    background: linear-gradient(135deg,#7dd3fc,#8be8df);
    box-shadow: 0 16rpx 42rpx rgba(0,0,0,.22),inset 0 1rpx 0 hsla(0,0%,100%,.28);
    color: #031014
}

.access-mode-modal__button--confirm.is-disabled {
    background: hsla(0,0%,100%,.052);
    border: 1rpx solid hsla(0,0%,100%,.07);
    box-shadow: none;
    color: rgba(148,163,184,.82)
}

.theme-day .access-mode-modal__mask {
    background: radial-gradient(circle at 50% 24%,rgba(8,145,178,.13),rgba(8,145,178,0) 34%),rgba(241,245,249,.86)
}

.theme-day .access-mode-modal__panel {
    background: linear-gradient(145deg,hsla(0,0%,100%,.98),rgba(236,254,255,.98));
    border-color: rgba(8,145,178,.12);
    box-shadow: 0 32rpx 100rpx rgba(15,23,42,.14),0 0 60rpx rgba(8,145,178,.08),inset 0 1rpx 0 hsla(0,0%,100%,.8)
}

.theme-day .access-mode-modal__title {
    color: #0f172a
}

.theme-day .access-mode-modal__subtitle {
    color: #64748b
}

.theme-day .access-mode-modal__button--cancel,.theme-day .access-mode-modal__button--confirm.is-disabled,.theme-day .access-mode-modal__field {
    background: rgba(15,23,42,.045);
    border-color: rgba(15,23,42,.08);
    color: #334155
}

.theme-day .access-mode-modal__input {
    color: #0f172a
}

@-webkit-keyframes access-mode-halo {
    0%,100% {
        opacity: .56;
        -webkit-transform: scale(.95);
        transform: scale(.95)
    }

    50% {
        opacity: .92;
        -webkit-transform: scale(1.06);
        transform: scale(1.06)
    }
}

@keyframes access-mode-halo {
    0%,100% {
        opacity: .56;
        -webkit-transform: scale(.95);
        transform: scale(.95)
    }

    50% {
        opacity: .92;
        -webkit-transform: scale(1.06);
        transform: scale(1.06)
    }
}

@-webkit-keyframes group-panel-in {
    0% {
        opacity: 0;
        -webkit-transform: translateY(18rpx);
        transform: translateY(18rpx)
    }

    100% {
        opacity: 1;
        -webkit-transform: translateY(0);
        transform: translateY(0)
    }
}

@keyframes group-panel-in {
    0% {
        opacity: 0;
        -webkit-transform: translateY(18rpx);
        transform: translateY(18rpx)
    }

    100% {
        opacity: 1;
        -webkit-transform: translateY(0);
        transform: translateY(0)
    }
}